{
    "output": ["DP-2"],

    "modules-right": [
        "cpu",
        "memory",
        "pulseaudio#input",
        "pulseaudio#output",
        "clock"
    ],

    "hyprland/workspaces": {
        "disable-scroll-wraparound": true,
        "smooth-scrolling-threshold": 4,
        "enable-bar-scroll": true,
        "format": "{icon}",
        "show-special": false,
        "format-icons": {
            "1": "λ",
            "2": "β",
            "3": "γ",
            "4": "δ",
            "5": "ε",
            "6": "Ψ"
        },
        "ignore-workspaces":[ "6", "Ψ" ],
        "persistent-workspaces": {
            "DP-2": [1, 2, 3, 4, 5]
        },
        "active-only": false,
        "sort-by-number": true
    }
}
