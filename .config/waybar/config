{
    "layer": "bottom",
    "position": "top",
    "name": "main",
    "include": ["~/.config/waybar/hosts/local.json"],

    "margin": "4 4 0",

    "modules-left": [
        "group/tray",
        "hyprland/workspaces",
        "hyprland/window"
    ],

    "modules-center": ["hyprland/submap"],

    "hyprland/submap": {
        "format": "{}",
        "tooltip": false
    },

    "group/tray": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 500,
            "transition-left-to-right": true,
            "children-class": "drawer-child"
        },
        "modules": ["custom/trayicon", "tray"]
    },

    "clock": {
        "interval": 1,
        "format": " {:%H:%M:%S   %d-%m }",
        "tooltip-format": "{:%d.%m.%Y  Week %W}\n\n<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "mode-mon-col": 3,
            "weeks-pos": "right",
            "on-scroll": 1,
            "format": {
                "months": "<span color='#9C8CE6'><b>{}</b></span>",
                "days": "<span color='#e5e5e5'><b>{}</b></span>",
                "weeks": "<span color='#6B7D8C'> W{}</span>",
                "weekdays": "<span color='#5A607A'><b>{}</b></span>",
                "today": "<span color='#ffcb6b'><b><u>{}</u></b></span>"
            }
        }
    },

   "cpu": {
       "interval": 4,
       "format": " {usage}%",
       "states": {
           "warning": 80,
           "critical": 95
        }
   },

    "memory": {
        "interval": 4,
        "format": " {percentage}%",
        "states": {
            "warning": 80,
            "critical": 95
        },
        "tooltip": "{}",
        "tooltip-format": "{used}/{total} GiB"
    },

    "hyprland/window": {
        "format": "{title}",
        "max-length": 48,
        "tooltip": false,
        "icon": true,
        "icon-size": 18
    },

    "pulseaudio#output": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon} {volume}%",
        "format-muted": "",
        "format-icons": {
            "headphone": "󰋋",
            "headset": "󰋋",
            "portable": "",
            "default": ["", "", ""]
        },
        "on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-click": "pavucontrol",
        "tooltip": true,
        "scroll-step": 5
    },

    "pulseaudio#input": {
        "format": " {format_source}%",
        "format-source": "{volume}",
        "format-source-muted": "",
        "on-scroll-up": "pactl set-source-volume @DEFAULT_SOURCE@ +5%",
        "on-scroll-down": "pactl set-source-volume @DEFAULT_SOURCE@ -5%",
        "max-volume": "100",
        "on-click-right": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
        "on-click": "pavucontrol",
        "tooltip-format": "{source_desc}"
    },

    "tray": {
        "icon-size": 17,
        "spacing": 8
    },

    "custom/trayicon": {
        "format": "",
        "tooltip": false
    }
}
