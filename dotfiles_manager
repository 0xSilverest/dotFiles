#!/bin/bash
set -euo pipefail

[ -n "${HOME:-}" ] || { echo "FATAL: \$HOME is empty"; exit 1; }

DOT_FILES_DIR="$HOME/dotFiles"
CONFIG_DIR="$HOME/.config"
BIN_DIR="$HOME/bin"

CONFIGS=(
    hypr
    waybar
    easyeffects
    qt6ct
    fish
    strawberry
    rofi
    kitty
    dunst
    gtk-3.0
    gtk-4.0
    omf
)

same_link() {
    [ -L "$1" ] && [ "$(readlink -f "$1")" = "$(readlink -f "$2")" ]
}

is_symlink_managed() {
    same_link "$CONFIG_DIR/fish" "$DOT_FILES_DIR/.config/fish"
}

create_symlink() {
    local source="$1" target="$2"
    if [ ! -e "$source" ]; then
        echo "  skip: backup source missing -> $source"
        return
    fi
    if same_link "$target" "$source"; then
        echo "  ok:   already linked -> $target"
        return
    fi
    if [ -e "$target" ] || [ -L "$target" ]; then
        local bak="${target}.bak.$(date +%Y%m%d%H%M%S)"
        mv "$target" "$bak"
        echo "  saved existing -> $bak"
    fi
    ln -s "$source" "$target"
    echo "  linked $target -> $source"
}

scrub_secrets() {
    local sb="$DOT_FILES_DIR/.config/strawberry/strawberry.conf"
    if [ -f "$sb" ]; then
        sed -i -E 's/^(access_token|refresh_token|user_token|password)=.+/\1=/' "$sb"
        echo "  scrubbed secrets from strawberry.conf"
    fi
}

sync_dotfiles() {
    if is_symlink_managed; then
        echo "Symlink-managed machine: configs already live in the repo via symlinks."
        echo "Nothing to copy; changes are captured by git directly."
        return
    fi

    echo "Syncing dotfiles..."
    mkdir -p "$DOT_FILES_DIR/.config" "$DOT_FILES_DIR/bin"

    for config in "${CONFIGS[@]}"; do
        local src="$CONFIG_DIR/$config"
        if [ ! -d "$src" ]; then
            echo "  warn: $config not found in $CONFIG_DIR (skipped)"
            continue
        fi
        rsync -a --delete "$src/" "$DOT_FILES_DIR/.config/$config/"
        echo "  synced $config"
    done

    mkdir -p "$DOT_FILES_DIR/.config/nvim/"
    cp "$CONFIG_DIR/nvim/init.lua" "$DOT_FILES_DIR/.config/nvim/init.lua"
    rsync -a --delete "$CONFIG_DIR/nvim/lua/" "$DOT_FILES_DIR/.config/nvim/lua/"
    echo "  synced nvim"

    if [ -d "$BIN_DIR" ]; then
        rsync -aL --delete "$BIN_DIR/" "$DOT_FILES_DIR/bin/"
        echo "  synced bin"
    else
        echo "  warn: $BIN_DIR not found"
    fi

    echo "Dotfiles sync complete."
}

link_host_profile() {
    local hosts_dir="$1" target="$2" ext="$3"
    [ -d "$hosts_dir" ] || return

    local chassis profile
    chassis="$(hostnamectl chassis 2>/dev/null || echo desktop)"
    case "$chassis" in
        laptop|tablet|handset|convertible) profile="laptop" ;;
        *) profile="desktop" ;;
    esac

    if [ -f "$hosts_dir/$profile.$ext" ]; then
        create_symlink "$hosts_dir/$profile.$ext" "$target"
        echo "  ${target#$CONFIG_DIR/} -> $profile (chassis: $chassis)"
    else
        echo "  warn: $hosts_dir/$profile.$ext missing, skipping host profile link"
    fi
}

restore_dotfiles() {
    echo "Restoring dotfiles (symlinking repo -> system)..."

    for config in "${CONFIGS[@]}"; do
        create_symlink "$DOT_FILES_DIR/.config/$config" "$CONFIG_DIR/$config"
    done

    link_host_profile "$CONFIG_DIR/hypr/hosts" "$CONFIG_DIR/hypr/hosts/local.conf" "conf"
    link_host_profile "$CONFIG_DIR/waybar/hosts" "$CONFIG_DIR/waybar/hosts/local.json" "json"
    link_host_profile "$CONFIG_DIR/hypr/hyprpaper-hosts" "$CONFIG_DIR/hypr/hyprpaper.conf" "conf"

    mkdir -p "$CONFIG_DIR/nvim"
    create_symlink "$DOT_FILES_DIR/.config/nvim/init.lua" "$CONFIG_DIR/nvim/init.lua"
    create_symlink "$DOT_FILES_DIR/.config/nvim/lua"      "$CONFIG_DIR/nvim/lua"

    mkdir -p "$BIN_DIR"
    if [ -d "$DOT_FILES_DIR/bin" ]; then
        for script in "$DOT_FILES_DIR"/bin/*; do
            [ -e "$script" ] || continue
            create_symlink "$script" "$BIN_DIR/$(basename "$script")"
        done
        echo "  restored bin"
    else
        echo "  warn: $DOT_FILES_DIR/bin not found"
    fi

    echo "Dotfiles restored."
}

case "${1:-}" in
    sync)
        sync_dotfiles
        scrub_secrets
        cd "$DOT_FILES_DIR" || exit 1
        git add -A
        git commit -m "${2:-Backing up dotfiles}" || echo "Nothing to commit."
        echo "Committed to git."
        ;;
    restore)
        restore_dotfiles
        ;;
    *)
        echo "Usage: $0 {sync [commit-msg] | restore}"
        exit 1
        ;;
esac
